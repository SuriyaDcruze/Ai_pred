# Copy to .env and fill in. Never commit .env.
AEGIS_ENV=development
AEGIS_LOG_LEVEL=INFO

# --- Model / inference ---
AEGIS_DEVICE=auto            # auto | cpu | cuda
AEGIS_MODEL_PATH=artifacts/model_best.pt
AEGIS_SEQ_LEN=128            # candles per input window

# --- Decision engine thresholds ---
AEGIS_MIN_CONFIDENCE=0.80
AEGIS_MIN_RR=2.0

# --- Conversational assistant (GPT-style) ---
# Set ANTHROPIC_API_KEY to enable natural-language chat via Claude. Without it,
# the assistant still works using the deterministic rule engine.
AEGIS_CHAT_LLM=true
AEGIS_CHAT_MODEL=claude-opus-4-8
ANTHROPIC_API_KEY=

# --- Risk ---
AEGIS_MAX_ACCOUNT_RISK=0.01  # 1% per trade
AEGIS_ACCOUNT_EQUITY=10000

# --- Exchanges (optional; public streams need no keys) ---
BINANCE_API_KEY=
BINANCE_API_SECRET=

# --- Infra (optional) ---
AEGIS_POSTGRES_DSN=postgresql+asyncpg://aegis:aegis@localhost:5432/aegis
AEGIS_REDIS_URL=redis://localhost:6379/0
